# ============================================================
# PredictIndia — Environment Variables
# Copy this to .env.local for local dev
# Add these in Vercel Dashboard → Project → Settings → Environment Variables
# ============================================================

# -----------------------------------------------------------
# POLYMARKET BUILDER PROGRAM
# Get from: polymarket.com → Profile → Builder API Keys
# -----------------------------------------------------------
BUILDER_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE
BUILDER_API_KEY=your_polymarket_builder_api_key_here

# -----------------------------------------------------------
# PUBLIC — exposed to browser (safe)
# -----------------------------------------------------------
NEXT_PUBLIC_BUILDER_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# -----------------------------------------------------------
# OPTIONAL: Override fallback INR rate
# Leave empty to auto-fetch from open.er-api.com
# -----------------------------------------------------------
# NEXT_PUBLIC_INR_FALLBACK_RATE=83.7
